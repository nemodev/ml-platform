# ML Platform Installer Configuration — r1 cluster
# This config targets the r1 cluster with kube-vip LoadBalancer + TLS.
# Static IPs have ports 8080/8443 firewall-opened; nodes have 30000-30100.

# ─── Namespace ───────────────────────────────────────────────────────────────
NAMESPACE=ml-platform

# KServe controller namespace (where kserve-controller-manager runs)
KSERVE_SYSTEM_NAMESPACE=kserve

# KServe release and deployment mode managed by installer scripts
KSERVE_VERSION=v0.16.0
KSERVE_DEFAULT_DEPLOYMENT_MODE=Standard

# Uninstall behavior: remove cluster-scoped KServe resources and CRDs
UNINSTALL_KSERVE_CLUSTER_RESOURCES=true

# Clean uninstall controls
UNINSTALL_DELETE_NAMESPACE=false
UNINSTALL_PURGE_PVC=true
UNINSTALL_PURGE_PV=true
# WARNING: when true and prefix is empty, all objects in S3_BUCKET are deleted.
UNINSTALL_PURGE_S3_DATA=false
# Optional prefix to limit S3 purge scope. Leave blank to use S3_PREFIX.
UNINSTALL_S3_PREFIX=

# ─── Container Images ────────────────────────────────────────────────────────
BACKEND_IMAGE=172.16.100.10:30500/ml-platform/backend:build-20260302152412
FRONTEND_IMAGE=172.16.100.10:30500/ml-platform/frontend:build-20260302143819
NOTEBOOK_IMAGE=172.16.100.10:30500/ml-platform/notebook:build-20260302143823
S3FS_SIDECAR_IMAGE=172.16.100.10:30500/ml-platform/s3fs-sidecar:build-20260302153258

# ─── Platform Access ─────────────────────────────────────────────────────────
# Using NodePort with TLS (kube-vip LB is unreliable on this cluster)
PLATFORM_URL=https://172.16.100.10:30443
FRONTEND_SERVICE_TYPE=NodePort
FRONTEND_NODE_PORT=30080
FRONTEND_HTTPS_NODE_PORT=30443

# ─── Keycloak ─────────────────────────────────────────────────────────────────
DEPLOY_KEYCLOAK=true
KEYCLOAK_REALM=ml-platform
KEYCLOAK_PORTAL_CLIENT_ID=ml-platform-portal
KEYCLOAK_JUPYTERHUB_CLIENT_ID=ml-platform-jupyterhub
KEYCLOAK_JUPYTERHUB_CLIENT_SECRET=ml-platform-jupyterhub-secret
JUPYTERHUB_API_TOKEN=ml-platform-jupyterhub-token

# ─── S3 Storage (external) ──────────────────────────────────────────────────
# S3_INTERNAL_ENDPOINT: The in-cluster URL all pods use to reach S3.
# S3_EXTERNAL_ENDPOINT: The actual S3 URL when it runs outside this namespace.
#   The installer creates an ExternalName service so the internal endpoint
#   resolves correctly. Leave blank if S3 is in the same namespace.
S3_INTERNAL_ENDPOINT=http://minio.ml-platform.svc:9000
S3_EXTERNAL_ENDPOINT=http://minio.o11y.svc.cluster.local:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=ml-platform
# Object key prefix for MLflow, Airflow logs, sample data, analysis, and pipelines.
S3_PREFIX=ml-platform

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DEPLOY_POSTGRESQL=true
POSTGRES_PASSWORD=localdevpassword
CREATE_KEYCLOAK_DB=true

# ─── ObjectBucketClaim ───────────────────────────────────────────────────────
DEPLOY_OBC=false
OBC_STORAGE_CLASS=s3-buckets

# ─── TLS ────────────────────────────────────────────────────────────────────
TLS_ENABLED=true
TLS_ISSUER=selfsigned
TLS_ISSUER_KIND=ClusterIssuer

# ─── Container Registry (Custom Notebook Images) ────────────────────────────
# REGISTRY_TYPE: "builtin" deploys an in-cluster Docker Distribution registry.
#                "external" skips registry deployment and uses the configured endpoint.
REGISTRY_TYPE=builtin
REGISTRY_ENDPOINT=registry.ml-platform.svc:5000
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
REGISTRY_INSECURE=true

# ─── Cluster DNS ─────────────────────────────────────────────────────────────
DNS_RESOLVER=10.43.0.10
CLUSTER_DOMAIN=cluster.local
