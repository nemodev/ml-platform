# ML Platform Installer Configuration — ml-test namespace
# Tests installation in a separate namespace, reusing MinIO from ml-platform.

# ─── Namespace ───────────────────────────────────────────────────────────────
NAMESPACE=ml-test

# ─── Container Images ────────────────────────────────────────────────────────
BACKEND_IMAGE=172.16.100.10:30500/ml-platform/backend:latest
FRONTEND_IMAGE=172.16.100.10:30500/ml-platform/frontend:latest
NOTEBOOK_IMAGE=172.16.100.10:30500/ml-platform/notebook:latest

# ─── Platform Access ─────────────────────────────────────────────────────────
# Option A: LoadBalancer + TLS (recommended)
# PLATFORM_URL=https://<static-ip>:8443
# FRONTEND_SERVICE_TYPE=LoadBalancer
# FRONTEND_HTTP_PORT=8080
# FRONTEND_HTTPS_PORT=8443
# FRONTEND_LOADBALANCER_IP=<static-ip>
# TLS_ENABLED=true

# Option B: NodePort (current)
PLATFORM_URL=http://172.16.100.10:30081
FRONTEND_SERVICE_TYPE=NodePort
FRONTEND_NODE_PORT=30081

# ─── Keycloak ─────────────────────────────────────────────────────────────────
DEPLOY_KEYCLOAK=true
KEYCLOAK_REALM=ml-platform
KEYCLOAK_PORTAL_CLIENT_ID=ml-platform-portal
KEYCLOAK_JUPYTERHUB_CLIENT_ID=ml-platform-jupyterhub
KEYCLOAK_JUPYTERHUB_CLIENT_SECRET=ml-platform-jupyterhub-secret
JUPYTERHUB_API_TOKEN=ml-platform-jupyterhub-token

# ─── S3 Storage (reuse MinIO from ml-platform namespace) ─────────────────────
S3_INTERNAL_ENDPOINT=http://minio.ml-test.svc:9000
S3_EXTERNAL_ENDPOINT=http://minio.o11y.svc.cluster.local:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=ml-test

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DEPLOY_POSTGRESQL=true
POSTGRES_PASSWORD=localdevpassword
CREATE_KEYCLOAK_DB=true

# ─── ObjectBucketClaim ───────────────────────────────────────────────────────
DEPLOY_OBC=false

# ─── TLS (optional) ──────────────────────────────────────────────────────────
# TLS_ENABLED=false
# TLS_ISSUER=selfsigned
# TLS_ISSUER_KIND=ClusterIssuer
# FRONTEND_HTTPS_NODE_PORT=30443

# ─── Cluster DNS ─────────────────────────────────────────────────────────────
DNS_RESOLVER=10.43.0.10
