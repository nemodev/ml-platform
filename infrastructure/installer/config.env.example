# ML Platform Installer Configuration
# Copy this file to config.env and adjust values for your environment.

# ─── Namespace ───────────────────────────────────────────────────────────────
NAMESPACE=ml-platform

# KServe controller namespace (where kserve-controller-manager runs)
KSERVE_SYSTEM_NAMESPACE=kserve

# KServe release and deployment mode managed by installer scripts
KSERVE_VERSION=v0.16.0
KSERVE_DEFAULT_DEPLOYMENT_MODE=Standard

# Uninstall behavior: remove cluster-scoped KServe resources and CRDs
UNINSTALL_KSERVE_CLUSTER_RESOURCES=true

# Clean uninstall controls
UNINSTALL_DELETE_NAMESPACE=false
UNINSTALL_PURGE_PVC=true
UNINSTALL_PURGE_PV=true
# WARNING: when true and prefix is empty, all objects in S3_BUCKET are deleted.
UNINSTALL_PURGE_S3_DATA=false
# Optional prefix to limit S3 purge scope. Leave blank to use S3_PREFIX.
UNINSTALL_S3_PREFIX=

# ─── Container Images ────────────────────────────────────────────────────────
# Full image references (registry/name:tag).
BACKEND_IMAGE=harbor.example.com/ml-platform/backend:latest
FRONTEND_IMAGE=harbor.example.com/ml-platform/frontend:latest
NOTEBOOK_IMAGE=harbor.example.com/ml-platform/notebook:latest

# ─── Platform Access ─────────────────────────────────────────────────────────
# External URL where users access the platform (no trailing slash)
# Examples:
#   NodePort:      http://172.16.100.10:30080
#   LoadBalancer:  https://172.16.100.10:8443  (with TLS)
PLATFORM_URL=http://172.16.100.10:30080

# Frontend K8s service type: NodePort, ClusterIP, or LoadBalancer
# LoadBalancer: recommended when kube-vip or cloud LB is available
# NodePort:     works when only NodePort range is firewall-opened
FRONTEND_SERVICE_TYPE=NodePort

# NodePort numbers (only when FRONTEND_SERVICE_TYPE=NodePort)
FRONTEND_NODE_PORT=30080

# Service ports exposed on the LoadBalancer IP or ClusterIP.
# For LoadBalancer, these MUST match your firewall rules (e.g. 8080/8443).
# For NodePort, these are internal only (users access via nodePort).
# FRONTEND_HTTP_PORT=80
# FRONTEND_HTTPS_PORT=443

# Request a specific LoadBalancer IP (optional, for kube-vip / cloud LB).
# FRONTEND_LOADBALANCER_IP=172.16.100.20

# ─── Keycloak ─────────────────────────────────────────────────────────────────
# Set to "true" to deploy Keycloak as a Deployment (uses shared PostgreSQL)
DEPLOY_KEYCLOAK=true
# When DEPLOY_KEYCLOAK=false, provide external Keycloak URL:
# KEYCLOAK_URL=http://keycloak.example.com:8080
KEYCLOAK_REALM=ml-platform
KEYCLOAK_PORTAL_CLIENT_ID=ml-platform-portal
KEYCLOAK_JUPYTERHUB_CLIENT_ID=ml-platform-jupyterhub
KEYCLOAK_JUPYTERHUB_CLIENT_SECRET=ml-platform-jupyterhub-secret
# KEYCLOAK_ADMIN_PASSWORD=admin

# API token shared between backend and JupyterHub "platform-api" service
JUPYTERHUB_API_TOKEN=ml-platform-jupyterhub-token

# ─── S3 Storage (external — not deployed by this installer) ──────────────────
# S3_INTERNAL_ENDPOINT: The in-cluster URL all pods use to reach S3.
S3_INTERNAL_ENDPOINT=http://minio.ml-platform.svc:9000

# S3_EXTERNAL_ENDPOINT: The actual S3 URL when it runs outside this namespace.
# The installer creates an ExternalName service so the internal endpoint
# resolves correctly. Leave blank if S3 is in the same namespace.
# S3_EXTERNAL_ENDPOINT=http://minio.o11y.svc.cluster.local:9000  # adjust cluster domain if needed

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Single bucket — all data stored under prefixed paths
S3_BUCKET=ml-platform
# Object key prefix for MLflow, Airflow logs, sample data, analysis, and pipelines.
S3_PREFIX=ml-platform

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Set to "true" to deploy PostgreSQL as a StatefulSet
DEPLOY_POSTGRESQL=true
POSTGRES_PASSWORD=localdevpassword
# When DEPLOY_POSTGRESQL=false, provide external PostgreSQL connection:
# POSTGRES_HOST=postgresql.example.com
# POSTGRES_PORT=5432
# Create keycloak database (set to true if Keycloak shares this PostgreSQL)
CREATE_KEYCLOAK_DB=true

# ─── Sample Data ───────────────────────────────────────────────────────────
# Set to "false" to skip provisioning sample Delta table data.
# Useful for restricted networks where the dataset download is blocked.
PROVISION_SAMPLE_DATA=true

# ─── ObjectBucketClaim ──────────────────────────────────────────────────────
# Set to "true" to create an ObjectBucketClaim for the S3 bucket
DEPLOY_OBC=false
OBC_STORAGE_CLASS=s3-buckets

# ─── TLS (optional) ──────────────────────────────────────────────────────────
# Enable HTTPS on the frontend reverse proxy. Requires cert-manager.
# When enabled, update PLATFORM_URL to use https:// and the appropriate port.
# Supports both IP addresses and DNS hostnames for certificate generation.
TLS_ENABLED=false
TLS_ISSUER=selfsigned
TLS_ISSUER_KIND=ClusterIssuer
# HTTPS NodePort (only when FRONTEND_SERVICE_TYPE=NodePort and TLS_ENABLED=true)
FRONTEND_HTTPS_NODE_PORT=30443

# ─── Container Registry (Custom Notebook Images) ────────────────────────────
# REGISTRY_TYPE: "builtin" deploys an in-cluster Docker Distribution registry.
#                "external" skips registry deployment and uses the configured endpoint.
REGISTRY_TYPE=builtin
# Registry endpoint used for pushing/pulling custom notebook images.
# For builtin: defaults to registry.<namespace>.svc:5000
# For external: set to your registry (e.g. harbor.example.com, ghcr.io/myorg)
REGISTRY_ENDPOINT=registry.ml-platform.svc:5000
# Credentials for external registry (leave blank for builtin)
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
# Set to "true" for registries without TLS (e.g. builtin registry over HTTP)
REGISTRY_INSECURE=true

# ─── Cluster DNS ─────────────────────────────────────────────────────────────
# ClusterIP of kube-dns / CoreDNS (used by nginx resolver directive)
DNS_RESOLVER=10.43.0.10
# Kubernetes cluster domain (default: cluster.local)
# Override if your cluster uses a custom domain (e.g. cluster.sm.us01)
CLUSTER_DOMAIN=cluster.local
